<html>
  <body>
    <h2>Student Account Linked</h2>
    <p>Hello {{parentName}},</p>
    <p>
      A student account for <strong>{{studentName}}</strong> has been created and
      linked to your parent profile at <strong>{{schoolName}}</strong>.
    </p>

    <div>
      <p><strong>Student ID:</strong> {{studentId}}</p>
      <p><strong>Username:</strong> {{studentUsername}}</p>
      <p><strong>Class:</strong> {{className}}</p>
      {{#if hasInstitutionalEmail}}
        <p><strong>School email:</strong> {{institutionalEmail}}</p>
      {{/if}}
    </div>

    {{#if hasPortalUrl}}
      <p>
        Review this student from your parent portal:
        <a href='{{portalUrl}}'>{{portalUrl}}</a>
      </p>
    {{/if}}

    <p>
      If any of these details look incorrect, please contact the school
      administration.
    </p>
  </body>
</html>
